# Brand
BRAND_NAME=Football Lacuna HQ
BRAND_TAGLINE=Football News. Every Second.
CONTENT_FOCUS=world_cup

# LLM
GROQ_API_KEY=

# Voiceover for daily/post-match videos
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_ENGLISH=

# Shared Google OAuth for YouTube + Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube uploads
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PLAYLIST_ID=

# Google Drive clip storage
GDRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# API-Football
API_FOOTBALL_KEY=
LIVE_SCORE_TIMEZONE=UTC

# Daily news videos
MIN_STORIES_FOR_DAILY=2
MAX_STORIES_FOR_DAILY=5

# Livestream
YOUTUBE_LIVE_STREAM_ID=
LIVESTREAM_STREAM_KEY=
LIVESTREAM_TARGET_LEAGUE_ID=1
LIVESTREAM_TARGET_SEASON=2026
LIVESTREAM_CHROMIUM_BIN=/usr/bin/google-chrome
LIVESTREAM_FFMPEG_BIN=/usr/bin/ffmpeg
LIVESTREAM_XVFB_BIN=/usr/bin/Xvfb
LIVECOMM_ENABLED=true
LIVECOMM_PROVIDER=edge-tts
LIVECOMM_LANGUAGE=english

# Post-match summary videos

LIVESTREAM_AUDIO_FILE=
LIVESTREAM_VIDEO_BITRATE=4500k
LIVESTREAM_AUDIO_BITRATE=128k
LIVESTREAM_FFMPEG_PRESET=veryfast
LIVECOMM_ENABLED=true
LIVECOMM_PROVIDER=edge-tts

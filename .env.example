# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pexels (free at pexels.com/api — used for B-roll video in news frame) ────
PEXELS_API_KEY=...

# Google Cloud Text-to-Speech (English voiceover)
# Use a service-account JSON path, or any Application Default Credentials setup.
GOOGLE_APPLICATION_CREDENTIALS=config/google_cloud_service_account.json
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Neural2-J
GOOGLE_TTS_SPEAKING_RATE=1.05

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_YORUBA=...        # Yoruba voice ID (used in Module 3/4)

# ── HeyGen ───────────────────────────────────────────────────────────────────
HEYGEN_API_KEY=...
HEYGEN_AVATAR_ID=...                  # The chosen AI presenter avatar ID

# ── Creatomate ───────────────────────────────────────────────────────────────
CREATOMATE_API_KEY=...
CREATOMATE_TEMPLATE_ID_LANDSCAPE=...  # 16:9 branded news template ID
CREATOMATE_TEMPLATE_ID_VERTICAL=...   # 9:16 short-form template ID

# ── Canva ─────────────────────────────────────────────────────────────────────
CANVA_API_KEY=...
CANVA_THUMBNAIL_TEMPLATE_ID=...       # Thumbnail template ID

# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# ── YouTube ───────────────────────────────────────────────────────────────────
# Path to your OAuth2 client secrets JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_PATH=config/youtube_client_secrets.json
YOUTUBE_TOKEN_PATH=config/youtube_token.json
# For the 24/7 livestream RTMP endpoint (from YouTube Studio > Go Live)
YOUTUBE_STREAM_KEY=...
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# ── Buffer ───────────────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=...
BUFFER_PROFILE_ID_YOUTUBE=...
BUFFER_PROFILE_ID_TIKTOK=...
BUFFER_PROFILE_ID_INSTAGRAM=...
BUFFER_PROFILE_ID_TWITTER=...

# ── Google Drive ──────────────────────────────────────────────────────────────
# Path to service account JSON downloaded from Google Cloud Console
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=config/gdrive_service_account.json
GOOGLE_DRIVE_FOLDER_ID=...            # Root folder ID for this project

# ── Brand ─────────────────────────────────────────────────────────────────────
BRAND_NAME=Football Lacuna HQ
BRAND_TAGLINE=Football News. Every Second.
CONTENT_FOCUS=world_cup
YOUTUBE_CHANNEL_ID=...

# ── AI Thumbnails ──────────────────────────────────────────────────────────────
THUMBNAIL_ENABLED=true
THUMBNAIL_MODEL=imagen-4.0-fast-generate-001
THUMBNAIL_WIDTH=1280
THUMBNAIL_HEIGHT=720
THUMBNAIL_CANDIDATES=2
GOOGLE_CLOUD_PROJECT=football-pulse-499015
GOOGLE_CLOUD_LOCATION=us-central1

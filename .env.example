POST_MATCH_TARGET_LEAGUE_ID=1
POST_MATCH_TARGET_SEASON=2026
POST_MATCH_TIMEZONE=UTC
POST_MATCH_LOOKAHEAD_HOURS=24
POST_MATCH_VERBOSE_LOGS=false
POST_MATCH_DEBUG_DIR=temp/post_match_debug

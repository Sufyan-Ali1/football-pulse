# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pexels (free at pexels.com/api — used for B-roll video in news frame) ────
PEXELS_API_KEY=...

# Google Cloud Text-to-Speech (English voiceover)
# Use a service-account JSON path, or any Application Default Credentials setup.
GOOGLE_APPLICATION_CREDENTIALS=config/google_cloud_service_account.json
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Neural2-J
GOOGLE_TTS_SPEAKING_RATE=1.05

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_YORUBA=...        # Yoruba voice ID (used in Module 3/4)
EDGE_TTS_VOICE_ENGLISH=en-US-AndrewNeural
EDGE_TTS_VOICE_YORUBA=en-US-AndrewNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# ── HeyGen ───────────────────────────────────────────────────────────────────
HEYGEN_API_KEY=...
HEYGEN_AVATAR_ID=...                  # The chosen AI presenter avatar ID

# ── Creatomate ───────────────────────────────────────────────────────────────
CREATOMATE_API_KEY=...
CREATOMATE_TEMPLATE_ID_LANDSCAPE=...  # 16:9 branded news template ID
CREATOMATE_TEMPLATE_ID_VERTICAL=...   # 9:16 short-form template ID

# ── Canva ─────────────────────────────────────────────────────────────────────
CANVA_API_KEY=...
CANVA_THUMBNAIL_TEMPLATE_ID=...       # Thumbnail template ID

# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# ── YouTube ───────────────────────────────────────────────────────────────────
# Path to your OAuth2 client secrets JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_PATH=config/youtube_client_secrets.json
YOUTUBE_TOKEN_PATH=config/youtube_token.json
# Livestream automation uses YOUTUBE_LIVE_STREAM_ID and LIVESTREAM_STREAM_KEY below.
API_FOOTBALL_KEY=...
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
LIVE_SCORE_POLL_SECONDS=30
LIVE_SCORE_TIMEZONE=UTC
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...
YOUTUBE_PLAYLIST_ID=
YOUTUBE_LIVE_STREAM_ID=...
YOUTUBE_LIVE_PRIVACY_STATUS=unlisted
YOUTUBE_LIVE_CATEGORY_ID=17
LIVESTREAM_STREAM_KEY=...
LIVESTREAM_BASE_URL=http://127.0.0.1:8000
LIVESTREAM_FIXTURE_ID=0
LIVESTREAM_TARGET_LEAGUE_ID=1
LIVESTREAM_TARGET_SEASON=2026
LIVESTREAM_POLL_SECONDS=30
LIVESTREAM_PREMATCH_LEAD_SECONDS=900
LIVESTREAM_POSTMATCH_GRACE_SECONDS=180

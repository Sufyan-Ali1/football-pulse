# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# ── YouTube ───────────────────────────────────────────────────────────────────
# Path to your OAuth2 client secrets JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_PATH=config/youtube_client_secrets.json
YOUTUBE_TOKEN_PATH=config/youtube_token.json
# For the 24/7 livestream RTMP endpoint (from YouTube Studio > Go Live)
YOUTUBE_STREAM_KEY=...
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# ── Buffer ───────────────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=...
BUFFER_PROFILE_ID_YOUTUBE=...
BUFFER_PROFILE_ID_TIKTOK=...
BUFFER_PROFILE_ID_INSTAGRAM=...
BUFFER_PROFILE_ID_TWITTER=...

# ── Google Drive ──────────────────────────────────────────────────────────────
# Path to service account JSON downloaded from Google Cloud Console
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=config/gdrive_service_account.json
GOOGLE_DRIVE_FOLDER_ID=...            # Root folder ID for this project

# ── Brand ─────────────────────────────────────────────────────────────────────
